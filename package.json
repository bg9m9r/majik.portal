{
  "name": "majik-portal",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "openapi:fetch": "curl -fsSL ${MAJIK_API:-http://localhost:5057}/openapi/v1.json -o openapi.json",
    "openapi:gen": "ng-openapi-gen --config ng-openapi-gen.json",
    "openapi": "npm run openapi:fetch && npm run openapi:gen",
    "e2e": "playwright test",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "private": true,
  "packageManager": "npm@11.14.1",
  "dependencies": {
    "@angular/cdk": "^21.2.13",
    "@angular/common": "^21.2.15",
    "@angular/compiler": "^21.2.15",
    "@angular/core": "^21.2.17",
    "@angular/forms": "^21.2.15",
    "@angular/platform-browser": "^21.2.15",
    "@angular/router": "^21.2.15",
    "@auth0/auth0-angular": "^2.9.0",
    "@microsoft/signalr": "^10.0.0",
    "@ngrx/operators": "^21.1.1",
    "@ngrx/signals": "^21.1.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.15",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "jsdom": "^29.1.1",
    "ng-openapi-gen": "^1.0.5",
    "postcss": "^8.5.15",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.2",
    "vitest": "^4.1.8"
  }
}
