  },
  "components": {
    "schemas": {
      "AttackerDeclarationDto": {
        "required": [
          "attackerInstanceId",
          "defenderId"
        ],
        "type": "object",
        "properties": {
          "attackerInstanceId": {
            "type": "string",
            "format": "uuid"
          },
          "defenderId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "BlockerDeclarationDto": {
        "required": [
          "blockerInstanceId",
          "attackerInstanceId"
        ],
        "type": "object",
        "properties": {
          "blockerInstanceId": {
            "type": "string",
            "format": "uuid"
          },
          "attackerInstanceId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "CardDto": {
        "required": [
          "name",
          "manaCost",
          "types",
          "power",
          "toughness",
          "isImplemented"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "manaCost": {
            "type": "string"
          },
          "types": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "power": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "toughness": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "isImplemented": {
            "type": "boolean"
          }
        }
      },
      "CardsError": {
        "required": [
          "error"
        ],
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "CreateDeckRequest": {
        "required": [
          "name",
          "mainboard",
          "sideboard"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "mainboard": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DeckCardEntryDto"
            }
          },
          "sideboard": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DeckCardEntryDto"
            }
          }
        }
      },
      "CreateMatchRequest": {
        "required": [
          "format",
          "visibility",
          "deckId",
          "clockMinutes"
        ],
        "type": "object",
        "properties": {
          "format": {
            "type": "string"
          },
          "visibility": {
            "type": "string"
          },
          "deckId": {
            "type": "string"
          },
          "clockMinutes": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "DeckCardEntryDto": {
        "required": [
          "name",
          "count"
        ],
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "count": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "DeckDto": {
        "required": [
          "id",
          "ownerSub",
          "name",
          "mainboard",
          "sideboard",
          "createdAt",
          "updatedAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "ownerSub": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "mainboard": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DeckCardEntryDto"
            }
          },
          "sideboard": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DeckCardEntryDto"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "DeckError": {
        "required": [
          "error"
        ],
        "type": "object",
        "properties": {
          "error": {
            "type": "string"
          },
          "validation": {
            "type": [
              "null",
              "array"
            ],
            "items": {
              "type": "string"
            }
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "GameCommand": {
        "required": [
          "$type"
        ],
        "type": "object",
        "anyOf": [
          {
            "$ref": "#/components/schemas/GameCommandPassPriorityCommand"
          },
          {
            "$ref": "#/components/schemas/GameCommandPlayLandCommand"
          },
          {
            "$ref": "#/components/schemas/GameCommandCastSpellCommand"
          },
          {
            "$ref": "#/components/schemas/GameCommandMulliganCommand"
          },
          {
            "$ref": "#/components/schemas/GameCommandChooseTargetsCommand"
          },
          {
            "$ref": "#/components/schemas/GameCommandChooseXCommand"
          },
          {
            "$ref": "#/components/schemas/GameCommandChooseModeCommand"
          },
          {
            "$ref": "#/components/schemas/GameCommandChooseManaCommand"
          },
          {
            "$ref": "#/components/schemas/GameCommandOrderTriggersCommand"
          },
          {
            "$ref": "#/components/schemas/GameCommandDeclareAttackersCommand"
          },
          {
            "$ref": "#/components/schemas/GameCommandDeclareBlockersCommand"
          },
          {
            "$ref": "#/components/schemas/GameCommandChooseCardsToBottomCommand"
          }
        ],
        "discriminator": {
          "propertyName": "$type",
          "mapping": {
            "pass": "#/components/schemas/GameCommandPassPriorityCommand",
            "play-land": "#/components/schemas/GameCommandPlayLandCommand",
            "cast": "#/components/schemas/GameCommandCastSpellCommand",
            "mulligan": "#/components/schemas/GameCommandMulliganCommand",
            "targets": "#/components/schemas/GameCommandChooseTargetsCommand",
            "x": "#/components/schemas/GameCommandChooseXCommand",
            "mode": "#/components/schemas/GameCommandChooseModeCommand",
            "mana": "#/components/schemas/GameCommandChooseManaCommand",
            "order-triggers": "#/components/schemas/GameCommandOrderTriggersCommand",
            "attackers": "#/components/schemas/GameCommandDeclareAttackersCommand",
            "blockers": "#/components/schemas/GameCommandDeclareBlockersCommand",
            "bottom": "#/components/schemas/GameCommandChooseCardsToBottomCommand"
          }
        }
      },
      "GameCommandCastSpellCommand": {
        "required": [
          "cardInstanceId",
          "targetInstanceIds",
          "xValue",
          "modeIndex"
        ],
        "properties": {
          "$type": {
            "enum": [
              "cast"
            ],
            "type": "string"
          },
          "cardInstanceId": {
            "type": "string",
            "format": "uuid"
          },
          "targetInstanceIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "xValue": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "modeIndex": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "playerId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "GameCommandChooseCardsToBottomCommand": {
        "required": [
          "cardInstanceIds"
        ],
        "properties": {
          "$type": {
            "enum": [
              "bottom"
            ],
            "type": "string"
          },
          "cardInstanceIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "playerId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "GameCommandChooseManaCommand": {
        "required": [
          "sourceInstanceIds"
        ],
        "properties": {
          "$type": {
            "enum": [
              "mana"
            ],
            "type": "string"
          },
          "sourceInstanceIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "playerId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "GameCommandChooseModeCommand": {
        "required": [
          "modeIndex"
        ],
        "properties": {
          "$type": {
            "enum": [
              "mode"
            ],
            "type": "string"
          },
          "modeIndex": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "playerId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "GameCommandChooseTargetsCommand": {
        "required": [
          "targetInstanceIds"
        ],
        "properties": {
          "$type": {
            "enum": [
              "targets"
            ],
            "type": "string"
          },
          "targetInstanceIds": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uuid"
            }
          },
          "playerId": {
            "type": "string",
            "format": "uuid"
          }
